{
  "name": "api-goldens",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "prettier": {
      "command": "prettier src --check",
      "options": {
        "cwd": "apps/api-goldens"
      }
    },
    "typecheck": {
      "command": "tsc --noEmit -p tsconfig.spec.json",
      "options": {
        "cwd": "apps/api-goldens"
      }
    },
    "run": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/api-goldens/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "test": {
      "command": "echo No tests."
    },
    "generateEnvironment": {
      "command": "sh scripts/generateApiGoldensEnvironment.sh"
    },
    "emptyLogsBucket": {
      "command": "aws s3 rm s3://$LOGS_BUCKET --recursive"
    }
  }
}
